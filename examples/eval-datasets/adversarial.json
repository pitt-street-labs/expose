      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-011",
      "description": "Subdomain takeover candidate -- CNAME points to deprovisioned cloud resource",
      "entity_type": "domain",
      "canonical_identifier": "old-feature.acme.example.com",
      "observations": [
        {
          "collector_id": "active-dns",
          "record_type": "CNAME",
          "value": "acme-old-feature.azurewebsites.net",
          "nxdomain": true
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-012",
      "description": "IP with BGP hijack indicators -- announced by unexpected ASN",
      "entity_type": "ip",
      "canonical_identifier": "203.0.113.250",
      "observations": [
        {
          "collector_id": "bgp-prefixes",
          "origin_asn": 99999,
          "expected_asn": 64512,
          "hijack_suspected": true
        },
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "nginx"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-013",
      "description": "Domain registered one day ago with tenant keywords -- likely brand abuse, not legitimate",
      "entity_type": "domain",
      "canonical_identifier": "acme-support-portal.example.net",
      "observations": [
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Quick Domains LLC",
          "matches_tenant": false,
          "registration_date": "2026-05-10",
          "domain_age_days": 1
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-014",
      "description": "IP with SSL cert containing tenant domain in SAN but cert is self-signed and untrusted",
      "entity_type": "ip",
      "canonical_identifier": "192.0.2.175",
      "observations": [
        {
          "collector_id": "tls-handshake",
          "subject": "acme.example.com",
          "issuer": "Self-Signed",
          "self_signed": true,
          "san_values": ["acme.example.com", "*.acme.example.com"]
        },
        {
          "collector_id": "cloud-range-check",
          "cloud_account_match": false,
          "provider": "unknown"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-015",
      "description": "Domain with multiple high-volume observations but all from untrusted or spoofable sources",
      "entity_type": "domain",
      "canonical_identifier": "totally-legit-acme.example.biz",
      "observations": [
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "Apache",
          "body_snippet": "Welcome to Acme Corp Official Website"
        },
        {
          "collector_id": "active-dns",
          "record_type": "TXT",
          "value": "v=spf1 include:acme.example.com ~all"
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Legitimate Business Corp",
          "matches_tenant": false
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    }
  ]
}
