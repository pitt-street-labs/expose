{
  "name": "adversarial",
  "category": "adversarial",
  "cases": [
    {
      "case_id": "ad-001",
      "description": "Typosquat domain designed to fool string matching -- 'Acme Corp Lookalike LLC' is not 'Acme Corp'",
      "entity_type": "domain",
      "canonical_identifier": "acme-corp.example.net",
      "observations": [
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Acme Corp Lookalike LLC",
          "matches_tenant": false
        },
        {
          "collector_id": "cert-transparency",
          "subject": "acme-corp.example.net",
          "issuer": "Let's Encrypt"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-002",
      "description": "IP with spoofed cloud signals -- 3 observations but no genuine cloud account match",
      "entity_type": "ip",
      "canonical_identifier": "198.51.100.222",
      "observations": [
        {
          "collector_id": "cloud-range-check",
          "cloud_account_match": false,
          "provider": "aws",
          "service_category": "ec2"
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Different Org",
          "matches_tenant": false
        },
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "nginx"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-003",
      "description": "Domain that looks like a subdomain of tenant apex but is actually a different TLD",
      "entity_type": "domain",
      "canonical_identifier": "acme.example.co",
      "observations": [
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Squatter Holdings",
          "matches_tenant": false
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-004",
      "description": "Honeypot IP with deliberately planted tenant-like banners -- 3 observations but no cloud match",
      "entity_type": "ip",
      "canonical_identifier": "192.0.2.200",
      "observations": [
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "Apache",
          "body_snippet": "Welcome to Acme Corp Portal"
        },
        {
          "collector_id": "active-dns",
          "record_type": "PTR",
          "value": "mail.acme.example.com"
        },
        {
          "collector_id": "cert-transparency",
          "subject": "acme-fake.example.com",
          "issuer": "Self-Signed"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-005",
      "description": "Homograph attack domain using visually similar characters (rn looks like m)",
      "entity_type": "domain",
      "canonical_identifier": "acrnecorp.example.com",
      "observations": [
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Phishing Operations Inc",
          "matches_tenant": false
        },
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "nginx",
          "body_snippet": "Acme Corp Login"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-006",
      "description": "Certificate overlap via shared CDN -- same cert issuer and SAN format as tenant but different org",
      "entity_type": "domain",
      "canonical_identifier": "unrelated-site.cdn-provider.example.net",
      "observations": [
        {
          "collector_id": "cert-transparency",
          "subject": "unrelated-site.cdn-provider.example.net",
          "issuer": "Let's Encrypt",
          "san_values": ["unrelated-site.cdn-provider.example.net"]
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-007",
      "description": "Domain with tenant company name in path but owned by news organization (press mention)",
      "entity_type": "domain",
      "canonical_identifier": "news-outlet.example.com",
      "observations": [
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "WordPress",
          "body_snippet": "Acme Corp announced quarterly earnings today"
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Global News Network",
          "matches_tenant": false
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-008",
      "description": "Phishing clone with 4 observations mimicking real tenant signals but no cloud match",
      "entity_type": "domain",
      "canonical_identifier": "secure-login-acme.example.org",
      "observations": [
        {
          "collector_id": "active-http",
          "status_code": 200,
          "server_header": "nginx",
          "body_snippet": "Acme Corp Employee Portal - Sign In"
        },
        {
          "collector_id": "cert-transparency",
          "subject": "secure-login-acme.example.org",
          "issuer": "Let's Encrypt"
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Privacy Protect LLC",
          "matches_tenant": false,
          "privacy_protected": true
        },
        {
          "collector_id": "active-dns",
          "record_type": "A",
          "value": "45.33.32.156"
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-009",
      "description": "IP previously owned by tenant (cloud elastic IP) now reassigned to different customer",
      "entity_type": "ip",
      "canonical_identifier": "52.87.100.200",
