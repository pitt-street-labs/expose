        {
          "collector_id": "cloud-range-check",
          "cloud_account_match": false,
          "provider": "aws",
          "previously_associated": true
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Amazon Technologies Inc",
          "matches_tenant": false
        }
      ],
      "expected_attribution": "not_yours",
      "expected_confidence_min": 0.0,
      "expected_confidence_max": 0.3
    },
    {
      "case_id": "ad-010",
      "description": "Domain with similar registrant name but different legal entity (Acme Industries vs Acme Corp)",
      "entity_type": "domain",
      "canonical_identifier": "acme-industries.example.com",
      "observations": [
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Acme Industries International",
          "matches_tenant": false
        },
        {
          "collector_id": "cert-transparency",
