    {
      "case_id": "cy-001",
      "description": "IP in tenant's authorized AWS account range with 3 collector confirmations including cloud match",
      "entity_type": "ip",
      "canonical_identifier": "203.0.113.42",
      "observations": [
        {
          "collector_id": "cloud-range-check",
          "cloud_account_match": true,
          "provider": "aws",
          "matched_range": "203.0.113.0/24"
        },
        {
          "collector_id": "rdap-whois",
          "registrant_org": "Acme Corp",
          "matches_tenant": true
        },
        {
          "collector_id": "cert-transparency",
          "subject": "*.acme.example.com",
          "issuer": "Let's Encrypt"
        }
      ],
      "expected_attribution": "confirmed",
      "expected_confidence_min": 0.95,
      "expected_confidence_max": 1.0
    },
